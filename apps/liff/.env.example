# ─── Funnel builder (?page=funnel) ───────────────────────
# URL: https://liff.line.me/{LIFF_ID}?page=funnel&preset=evergreen_launch&ref=lp-a

VITE_FUNNEL_TITLE=LINE特典を受け取る
VITE_FUNNEL_INTRO_TITLE=特典をお受け取りください
VITE_FUNNEL_INTRO_BODY=いくつかの質問にお答えいただくと、あなたに最適な特典をご案内します。
VITE_FUNNEL_INTRO_CTA=スタート

# Quiz Q1 — options as JSON array [{label, value}]
VITE_FUNNEL_Q1=現在の状況を教えてください
VITE_FUNNEL_Q1_OPTIONS=[{"label":"初心者・これから始める","value":"beginner"},{"label":"ある程度やっているが伸び悩んでいる","value":"intermediate"},{"label":"月10万以上の実績あり","value":"advanced"}]

# Quiz Q2
VITE_FUNNEL_Q2=一番の悩みは何ですか？
VITE_FUNNEL_Q2_OPTIONS=[{"label":"何から始めればいいか分からない","value":"direction"},{"label":"時間がなかなか取れない","value":"time"},{"label":"結果が出るか不安","value":"confidence"},{"label":"仲間・コミュニティがない","value":"community"}]

# Form step — LINE Harness form ID (optional; omit to skip form step)
VITE_FUNNEL_FORM_ID=

# Offer display text
VITE_FUNNEL_OFFER_NAME=特別オファー
VITE_FUNNEL_OFFER_DESC=
VITE_FUNNEL_OFFER_PRICE=
